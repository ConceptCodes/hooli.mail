# Required: your mail server domain (for Let's Encrypt)
DOMAIN=mail.example.com

# Required: Postgres credentials (used by both postgres and mailserver services)
POSTGRES_USER=hoolimail
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=hoolimail

# Optional: email for Let's Encrypt certificate expiry notices
ACME_EMAIL=admin@example.com

# Optional: seed an admin user on first run
SEED_EMAIL=admin@example.com
SEED_PASS=your-secure-password
